# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

region              = "us-east-1"
foundation_model_id = "us.anthropic.claude-sonnet-4-6"

# Langfuse credentials (cloud.langfuse.com). Stored in Secrets Manager at apply time.
langfuse_host       = "https://cloud.langfuse.com"
langfuse_public_key = "pk-lf-CHANGE-ME"
langfuse_secret_key = "sk-lf-CHANGE-ME"

# Optional: extra IAM principals beyond the deploying caller identity.
# lf_admin_principal_arns = ["arn:aws:iam::123456789012:role/SomeOperatorRole"]
# trusted_assumer_arns    = ["arn:aws:iam::123456789012:role/GitHubActionsCI"]

# Optional: SageMaker Unified Studio project execution roles that should see the
# governed database inside Studio. Each gets Admin-equivalent LF grants on the
# database (SELECT on all tables + DESCRIBE on the db). Leave empty for clients
# that don't use SMUS.
# smus_reader_role_arns = [
#   "arn:aws:iam::123456789012:role/service-role/AmazonSageMakerAdminIAMExecutionRole",
# ]

# tags = {
#   CostCenter = "ms3dm-flagship"
# }
